<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:Csp/etc/csp_whitelist.xsd">

    <policies>

        <!-- Styles -->
        <policy id="style-src">
            <values>
                <value id="google-fonts-css" type="host">
                    https://fonts.googleapis.com
                </value>
            </values>
        </policy>

        <!-- Fonts -->
        <policy id="font-src">
            <values>
                <value id="google-fonts-static" type="host">
                    https://fonts.gstatic.com
                </value>
            </values>
        </policy>

        <!-- Scripts -->
        <policy id="script-src">
            <values>
                <value id="googletagmanager" type="host">
                    https://www.googletagmanager.com
                </value>
                <value id="google-analytics" type="host">
                    https://www.google-analytics.com
                </value>
                <value id="google-analytics-region1" type="host">
                    https://region1.google-analytics.com
                </value>
                <value id="hotjar-static" type="host">
                    https://static.hotjar.com
                </value>
                <value id="google-recaptcha" type="host">
                    https://www.google.com
                </value>
                <value id="google-static" type="host">
                    https://www.gstatic.com
                </value>
            </values>
        </policy>

        <!-- AJAX / API -->
        <policy id="connect-src">
            <values>
                <value id="ga-connect" type="host">
                    https://www.google-analytics.com
                </value>
                <value id="ga-region-connect" type="host">
                    https://region1.google-analytics.com
                </value>
                <value id="hotjar-connect" type="host">
                    https://*.hotjar.com
                </value>
                <value id="google-connect" type="host">
                    https://www.google.com
                </value>
            </values>
        </policy>

        <!-- reCAPTCHA iframe -->
        <policy id="frame-src">
            <values>
                <value id="google-frame" type="host">
                    https://www.google.com
                </value>
            </values>
        </policy>

    </policies>

</csp_whitelist>
<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">

    <group id="default">
        <job name="beautyfort_update_price"
             instance="BeautyFort\BeautyfortProductImport\Cron\UpdatePrice"
             method="execute">
            <!-- Every 4 hours -->
            <schedule>0 */4 * * *</schedule>
        </job>
    </group>
</config>
